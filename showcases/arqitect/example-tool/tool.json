{
  "name": "currency-converter",
  "version": "1.0.0",
  "description": "Converts between currencies using the Frankfurter exchange rate API.",
  "command": ["python3", "tool.py"],
  "env": {},
  "tools": [
    {
      "name": "convert_currency",
      "description": "Convert an amount from one currency to another using live exchange rates.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "Amount to convert"
          },
          "from": {
            "type": "string",
            "description": "ISO 4217 source currency code (e.g. USD)"
          },
          "to": {
            "type": "string",
            "description": "ISO 4217 target currency code (e.g. EUR)"
          }
        },
        "required": ["amount", "from", "to"]
      }
    }
  ],
  "armor": {
    "path": "armor.json",
    "profile": "network",
    "allow": [
      "api.frankfurter.app:443"
    ]
  }
}
